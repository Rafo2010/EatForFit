<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F0E8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="18dp"
        android:paddingTop="20dp"
        android:paddingBottom="32dp">

        <!-- ══ Header ══════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Meal Plan"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/bronze_spice"/>

                <TextView
                    android:id="@+id/tvPlanDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today"
                    android:textSize="13sp"
                    android:textColor="@color/grey"/>

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegeneratePlan"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="↺ New Plan"
                android:textAllCaps="false"
                android:textColor="@color/bronze_spice"
                android:textSize="12sp"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="22dp"
                app:strokeColor="@color/bronze_spice"
                app:strokeWidth="1.5dp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1.5dp"
            android:background="@color/sunfower_gold"
            android:layout_marginBottom="16dp"/>

        <!-- ══ Daily Progress card ════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DAILY PROGRESS"
                    android:textSize="10sp"
                    android:letterSpacing="0.14"
                    android:textStyle="bold"
                    android:textColor="#BCAAA4"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvDailyGoalSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔥 0 / 2000 kcal  ·  0% of plan"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/bronze_spice"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scan food → assign a meal slot → watch your progress fill up!"
                    android:textSize="11sp"
                    android:textColor="@color/grey"
                    android:lineSpacingExtra="2dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══ Water Tracker card ══════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:gravity="center"
                        android:background="#E3F2FD">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💧"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Water Tracker"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1565C0"
                        android:layout_marginStart="10dp"/>

                    <TextView
                        android:id="@+id/tvWaterCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 8 glasses"
                        android:textSize="11sp"
                        android:textColor="#2196F3"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- Tap-to-fill glasses row -->
                <LinearLayout
                    android:id="@+id/layoutWaterGlasses"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap a glass to log it. Goal: 8 glasses / day."
                    android:textSize="10sp"
                    android:textColor="#AAAAAA"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══ Loading ════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutMealPlanLoading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="52dp"
            android:visibility="visible">

            <ProgressBar
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:indeterminateTint="@color/bronze_spice"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤖 Building your plan…"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/bronze_spice"
                android:layout_marginTop="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Personalizing based on your goals"
                android:textSize="11sp"
                android:textColor="@color/grey"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- ══ Error ══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutMealPlanError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="36dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠️"
                android:textSize="44sp"/>

            <TextView
                android:id="@+id/tvMealPlanError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Could not generate meal plan"
                android:textSize="13sp"
                android:textColor="@color/grey"
                android:gravity="center"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="2dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMealPlanRetry"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Try Again"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:layout_marginTop="18dp"
                app:cornerRadius="24dp"
                app:backgroundTint="@color/bronze_spice"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutTimeline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/timelineSlots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#FFF8F0"
            android:gravity="center"
            android:padding="12dp"
            android:text="🌟 Consistency beats perfection. Log every meal!"
            android:textColor="#BF360C"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>